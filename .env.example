MAGON_ENV=local
MAGON_FOUNDATION_DATABASE_URL=postgresql+psycopg://magon:magon@127.0.0.1:5432/magon
MAGON_FOUNDATION_REDIS_URL=redis://127.0.0.1:6379/0
MAGON_FOUNDATION_CELERY_BROKER_URL=redis://127.0.0.1:6379/1
MAGON_FOUNDATION_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
MAGON_FOUNDATION_HOST=0.0.0.0
MAGON_FOUNDATION_PORT=8091
MAGON_FOUNDATION_LEGACY_ENABLED=false
MAGON_FOUNDATION_DEFAULT_ADMIN_EMAIL=admin@example.com
MAGON_FOUNDATION_DEFAULT_ADMIN_PASSWORD=admin123
MAGON_FOUNDATION_DEFAULT_OPERATOR_EMAIL=operator@example.com
MAGON_FOUNDATION_DEFAULT_OPERATOR_PASSWORD=operator123
MAGON_FOUNDATION_DEFAULT_CUSTOMER_EMAIL=customer@example.com
MAGON_FOUNDATION_DEFAULT_CUSTOMER_PASSWORD=customer123
MAGON_FOUNDATION_LOG_LEVEL=INFO
MAGON_FOUNDATION_LLM_ENABLED=false
MAGON_FOUNDATION_LLM_PROVIDER=openai
MAGON_FOUNDATION_LLM_MODEL=gpt-5.2
MAGON_FOUNDATION_LLM_BASE_URL=
MAGON_FOUNDATION_LLM_TIMEOUT_SECONDS=20
MAGON_FOUNDATION_LLM_MAX_INPUT_CHARS=12000
OPENAI_API_KEY=

MAGON_STANDALONE_DB_PATH=.platform_data/platform.sqlite3
MAGON_STANDALONE_HOST=0.0.0.0
MAGON_STANDALONE_PORT=8091
MAGON_STANDALONE_DEFAULT_QUERY=printing packaging vietnam
MAGON_STANDALONE_DEFAULT_COUNTRY=VN
MAGON_STANDALONE_INTEGRATION_TOKEN=dev-sync-token

# Backward-compatible aliases still accepted:
# SUPPLIER_INTELLIGENCE_DB_PATH=.platform_data/platform.sqlite3
# SUPPLIER_INTELLIGENCE_SYNC_TOKEN=dev-sync-token
