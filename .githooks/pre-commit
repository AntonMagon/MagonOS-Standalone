#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

MEMORY_FILE=".codex/project-memory.md"
PRODUCT_OWNED_PATTERN='^(src/|apps/web/|scripts/|tests/|AGENTS\.md$|docs/current-project-state\.md$|docs/ru/|\.codex/config\.toml$|docs/repo-workflow\.md$)'
RUSSIAN_DOCS_PATTERN='^docs/ru/'

if [[ ! -f "$MEMORY_FILE" ]]; then
  echo "pre-commit: missing $MEMORY_FILE" >&2
  exit 1
fi

if ! grep -q "<!-- ACTIVE:START -->" "$MEMORY_FILE" || ! grep -q "<!-- ACTIVE:END -->" "$MEMORY_FILE"; then
  echo "pre-commit: $MEMORY_FILE is missing ACTIVE markers" >&2
  exit 1
fi

if ! grep -q "<!-- WORKLOG:START -->" "$MEMORY_FILE" || ! grep -q "<!-- WORKLOG:END -->" "$MEMORY_FILE"; then
  echo "pre-commit: $MEMORY_FILE is missing WORKLOG markers" >&2
  exit 1
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMRT)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

if printf '%s\n' "$staged_files" | grep -Eq "$PRODUCT_OWNED_PATTERN"; then
  if ! printf '%s\n' "$staged_files" | grep -qx "$MEMORY_FILE"; then
    echo "pre-commit: product-owned changes require a staged $MEMORY_FILE update" >&2
    echo "Run: ./.venv/bin/python scripts/finalize_task.py --summary \"...\" --changed \"...\" --verify \"./scripts/verify_workflow.sh\"" >&2
    exit 1
  fi
  if ! printf '%s\n' "$staged_files" | grep -Eq "$RUSSIAN_DOCS_PATTERN"; then
    echo "pre-commit: product-owned changes require at least one staged docs/ru/ update" >&2
    echo "Document the change in Russian under docs/ru/ before committing." >&2
    exit 1
  fi
fi

./scripts/restore_context.sh --check >/dev/null
